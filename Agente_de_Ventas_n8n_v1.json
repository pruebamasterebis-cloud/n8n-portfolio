    {
      "id": "00b9600b-9363-4ddb-828c-e135cf5872ad",
      "name": "Normalizar lead",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        220,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "5ba0a6b2-6b40-43a0-90a8-7055397beba7",
              "name": "nombre",
              "type": "string",
              "value": "={{ $json.body.nombre }}"
            },
            {
              "id": "c43c94a3-ea5d-4fad-a96f-ae4856264cea",
              "name": "email",
              "type": "string",
              "value": "={{ $json.body.email }}"
            },
            {
              "id": "92ce04d0-e320-4b10-9bd5-f9388af2f9f2",
              "name": "empresa",
              "type": "string",
              "value": "={{ $json.body.empresa }}"
            },
            {
              "id": "b980291e-7c17-4ead-9c50-aeebb420bdfd",
              "name": "mensaje",
              "type": "string",
              "value": "={{ $json.body.mensaje }}"
            },
            {
              "id": "6687c49f-c2f8-4830-9d4e-222ae74b5287",
              "name": "fecha",
              "type": "string",
              "value": "={{ $now.toISO() }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "b51a8658-758f-4b28-921f-379dba92d2c7",
      "name": "Agente de Ventas",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        460,
        300
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Lead nuevo:\nNombre: {{ $json.nombre }}\nEmail: {{ $json.email }}\nEmpresa: {{ $json.empresa }}\nMensaje: {{ $json.mensaje }}",
        "options": {
          "systemMessage": "Eres el Agente de Ventas de Nubia, agencia de IA y automatizacion para pymes. Recibes un lead del formulario web. Tu trabajo: 1) Investiga la empresa del lead con la herramienta de busqueda web. 2) Consulta el CRM para ver si ya existe historial. 3) Cualifica el lead con criterios BANT y asigna un score de 0 a 100. 4) Redacta un email de primer contacto personalizado, en el tono de Nubia: profesional, cercano y orientado a resultados. Responde UNICAMENTE con un JSON valido, sin markdown, con esta estructura: {\"score\": number, \"segmento\": \"caliente|tibio|frio\", \"resumen\": string, \"asunto_email\": string, \"cuerpo_email\": string}"
        }
      }
    },
    {
      "id": "eb8e2c31-05bd-4d43-8de8-8f5cb1a8c4a2",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [
        380,
        520
      ],
      "parameters": {
        "model": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "options": {
          "temperature": 0.4
        }
      }
    },
    {
      "id": "d269d4bf-e433-4663-9fd5-6bd88a849a04",

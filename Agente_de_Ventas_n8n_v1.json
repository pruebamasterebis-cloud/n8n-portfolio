        "options": {}
      }
    },
    {
      "id": "2c4a05a4-d4df-4a69-b81f-d76256592838",
      "name": "Consultar CRM",
      "type": "n8n-nodes-base.googleSheetsTool",
      "typeVersion": 4.5,
      "position": [
        700,
        520
      ],
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Lee el CRM de Nubia para comprobar si el lead o su empresa ya existen y con que estado.",
        "documentId": {
          "__rl": true,
          "value": "CRM_Nubia",
          "mode": "name"
        },
        "sheetName": {
          "__rl": true,
          "value": "Leads",
          "mode": "name"
        }
      }
    },
    {
      "id": "d66b6112-b215-4e36-8beb-1af079771751",
      "name": "Parsear cualificacion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        300
      ],
      "parameters": {
        "jsCode": "const out = JSON.parse($json.output.replace(/```json|```/g, '').trim());\nreturn [{ json: { ...$('Normalizar lead').item.json, ...out } }];"
      }
    },
    {
      "id": "9f2bf53a-3b76-462c-9c27-3eae9f9b460f",
      "name": "Lead cualificado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        940,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "f6449e52-4f3a-4973-a088-e4eb3197a229",
              "leftValue": "={{ $json.score }}",
              "rightValue": 60,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        }
      }
    },
    {
      "id": "2920f2f9-41c2-4cf9-bd96-abe7d9b8d790",
      "name": "Enviar email de contacto",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        1160,
        200
      ],
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "={{ $json.asunto_email }}",
        "message": "={{ $json.cuerpo_email }}",
        "options": {}
      }
    },
    {

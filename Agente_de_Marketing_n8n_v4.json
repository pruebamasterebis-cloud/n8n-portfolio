    {
      "id": "51df4c9e-ad67-4902-ab42-51794c944ae8",
      "name": "Agente de Marketing",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        880,
        200
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Contenido a crear:\nTema: {{ $json.tema }}\nPilar: {{ $json.pilar }}\nCanal: {{ $json.canal }}\nFormato: {{ $json.formato }}",
        "options": {
          "systemMessage": "Eres el Agente de Marketing de Nubia, agencia de IA y automatizacion para pymes. Mision de Nubia: liberar a las pymes de las tareas repetitivas. Propuesta de valor: automatizacion de procesos con IA sin necesidad de equipo tecnico propio. Tono de marca: profesional pero cercano, didactico y orientado a resultados. Recibes un contenido planificado del calendario editorial (tema, pilar, canal y formato). Tu trabajo: 1) Usa la busqueda web para encontrar datos, tendencias o ejemplos recientes que aporten valor al tema. 2) Consulta la herramienta de contenidos publicados para NO repetir enfoques ni titulares ya usados. 3) Redacta el contenido final adaptado al canal y formato indicados (longitud y estilo apropiados: post de LinkedIn, hilo, articulo de blog, newsletter...). Responde UNICAMENTE con un JSON valido, sin markdown: {\"titular\": string, \"contenido\": string, \"hashtags\": string, \"fuentes\": string}"
        }
      }
    },
    {
      "id": "90fe90ee-8003-45ef-9394-48b80f2db810",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [
        800,
        420
      ],
      "parameters": {
        "model": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "options": {
          "temperature": 0.7
        }
      }
    },
    {
      "id": "61fef1c5-1383-4bab-a340-fd3bddb742e1",
      "name": "Buscar tendencias (web)",
      "type": "@n8n/n8n-nodes-langchain.toolSerpApi",
      "typeVersion": 1,
      "position": [

        420
      ],
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Lee el calendario editorial de Nubia para consultar titulares y temas ya publicados y evitar repeticiones.",
        "documentId": {
          "__rl": true,
          "value": "Calendario_Editorial",
          "mode": "name"
        },
        "sheetName": {
          "__rl": true,

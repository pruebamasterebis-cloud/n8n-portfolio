    },
    {
      "id": "2596d0d7-3484-473c-b8f7-2788ebec8801",
      "name": "Parsear contenido",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        200
      ],
      "parameters": {
        "jsCode": "const out = JSON.parse($json.output.replace(/```json|```/g, '').trim());\nreturn [{ json: { ...$('Preparar contenido').item.json, ...out } }];"
      }
    },
    {
      "id": "730081ed-f2e0-488c-aaa8-fedc841d2f67",
      "name": "Aprobar contenido (Slack)",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        1360,
        200
      ],
      "parameters": {
        "operation": "sendAndWait",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "#nubia-marketing",
          "mode": "name"
        },
        "message": "=:memo: Contenido para {{ $json.canal }} ({{ $json.formato }})\n*{{ $json.titular }}*\n\n{{ $json.contenido }}\n\n{{ $json.hashtags }}\n\nAprobar publicacion?",
        "approvalOptions": {
